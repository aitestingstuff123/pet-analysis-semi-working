rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - email: string (required)
    //   - displayName: string
    //   - photoURL: string
    //   - role: string (required, 'user' | 'admin')
    //   - createdAt: timestamp
    //
    // Collection: analyses
    // Document ID: {analysisId}
    // Fields:
    //   - userId: string (required)
    //   - petId: string
    //   - petName: string
    //   - mediaUrl: string
    //   - mediaType: string ('video' | 'audio')
    //   - status: string ('pending' | 'processing' | 'completed' | 'failed')
    //   - userQuestion: string
    //   - result: map
    //   - createdAt: timestamp
    //
    // Collection: pets
    // Document ID: {petId}
    // Fields:
    //   - userId: string (required)
    //   - name: string (required)
    //   - species: string (required, 'dog' | 'cat' | 'other')
    //   - breed: string
    //   - age: string
    //   - personality: string
    //   - createdAt: timestamp
    //
    // Collection: analyses/{analysisId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - analysisId: string (required)
    //   - userId: string
    //   - role: string (required, 'user' | 'assistant')
    //   - content: string (required)
    //   - createdAt: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "mejai0123@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string &&
             data.role in ['user', 'admin'];
    }

    function isValidAnalysis(data) {
      return data.keys().hasAll(['userId', 'status', 'createdAt']) &&
             data.userId is string &&
             data.status in ['pending', 'processing', 'completed', 'failed'];
    }

    function isValidPet(data) {
      return data.keys().hasAll(['userId', 'name', 'species']) &&
             data.userId is string &&
             data.name is string &&
             data.species in ['dog', 'cat', 'other'];
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['analysisId', 'role', 'content', 'createdAt']) &&
             data.analysisId is string &&
             data.role in ['user', 'assistant'] &&
             data.content is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
