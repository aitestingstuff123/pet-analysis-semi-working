rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper to check if user is admin
    function isAdmin() {
      return request.auth != null && 
        (firestore.get(/databases/ai-studio-53ddde92-ff15-462f-b8a9-38246ba8ede2/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "mejai0123@gmail.com");
    }

    // User-specific analysis files
    match /analyses/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
