{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Analysis": {
      "title": "Analysis",
      "description": "Pet behavior analysis result",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "petName": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "mediaType": { "type": "string", "enum": ["video", "audio"] },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "failed"] },
        "result": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/analyses/{analysisId}": {
      "schema": "Analysis",
      "description": "Behavior analysis records"
    }
  }
}
